{
  "name": "adotui",
  "module": "src/main.tsx",
  "type": "module",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "bin": {
    "adotui": "bin/adotui.js"
  },
  "files": [
    "bin",
    "dist",
    "README.md"
  ],
  "scripts": {
    "build:cli": "bun run dev/build-cli.ts",
    "dev": "bun run --watch src/main.tsx",
    "start": "bun run src/main.tsx",
    "typecheck": "bun x tsc -p tsconfig.json",
    "prepack": "bun run build:cli"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19.2.17"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@git-diff-view/cli": "^0.1.8",
    "@git-diff-view/react": "^0.1.6",
    "git-diff-view": "^0.0.13",
    "ink": "^7.1.0",
    "ink-spinner": "^5.0.0",
    "react": "^19.2.7"
  }
}
