{
  "name": "adotui",
  "version": "0.1.0",
  "description": "Terminal UI for managing Azure DevOps pull requests",
  "main": "dist/main.js",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "azure",
    "devops",
    "pull-request",
    "tui",
    "ink",
    "cli"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "bin": {
    "adotui": "bin/adotui.js"
  },
  "files": [
    "bin",
    "dist",
    "README.md"
  ],
  "scripts": {
    "build:cli": "bun run dev/build-cli.ts",
    "dev": "bun run --watch src/main.tsx",
    "start": "bun run src/main.tsx",
    "typecheck": "bun x tsc -p tsconfig.json",
    "test": "bun test",
    "prepack": "bun run build:cli"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19.2.17",
    "ink-testing-library": "^4.0.0",
    "typescript": "^5"
  },
  "dependencies": {
    "@git-diff-view/cli": "^0.1.8",
    "@git-diff-view/react": "^0.1.6",
    "git-diff-view": "^0.0.13",
    "immer": "^11.1.11",
    "ink": "^7.1.0",
    "ink-spinner": "^5.0.0",
    "react": "^19.2.7",
    "zustand": "^5.0.14"
  }
}